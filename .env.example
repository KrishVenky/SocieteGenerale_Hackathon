GROQ_API_KEY=Enter your GROQ API key here (e.g., gsk_yourkeyhere)
GROQ_MODEL=llama-3.3-70b-versatile

# Data paths
PS4_LOGS_PATH=data/Problem_04_Data_Access/sample_data/data_access_logs.csv
PS4_PROFILES_PATH=data/Problem_04_Data_Access/sample_data/user_profiles.csv
PS4_LABELS_PATH=data/Problem_04_Data_Access/sample_data/data_access_labels.csv

# Processed output paths
FEATURES_PATH=data/processed/real/features.parquet
BASELINES_PATH=data/processed/real/user_baselines.parquet
DEMO_EVENTS_PATH=data/processed/real/demo_replay/scripted_events.jsonl

# App config
DEMO_MODE=true
RISK_THRESHOLD=65
STREAM_NARRATIVE=true
BASELINE_DAYS=30
IP_ENTROPY_WINDOW_DAYS=7
PEER_GROUP_MIN_USERS=3
